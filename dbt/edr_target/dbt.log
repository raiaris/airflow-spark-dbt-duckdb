{"data": {"conn_name": "macro_log_macro_results", "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"80d859c2-8e0c-42ed-a5b9-9341fd6a7c14\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n            with dbt_artifacts_snapshots as (\n                select \n                  name,\n                  case when alias is not null then alias\n                  else name end as table_name,\n                  unique_id,\n                  owner as owners,\n                  tags,\n                  package_name,\n                  description,\n                  meta,\n                  materialization,\n                  database_name,\n                  schema_name,\n                  depends_on_macros,\n                  depends_on_nodes,\n                  original_path as full_path,\n                  path,\n                  patch_path,\n                  generated_at,\n                  unique_key,\n                  incremental_strategy\n                from \"fraud_warehouse\".\"main_elementary\".\"dbt_snapshots\"\n              )\n            select * from dbt_artifacts_snapshots\n        \n\n  "}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "80d859c2-8e0c-42ed-a5b9-9341fd6a7c14", "level": "debug", "msg": "On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"80d859c2-8e0c-42ed-a5b9-9341fd6a7c14\", \"package_name\": \"elementary\