location_region,\\n    round(avg_risk_score, 4) as avg_risk_score\\nfrom base\\norder by avg_risk_score desc\", \"generated_at\": \"2026-05-24 20:15:37\"}]--ELEMENTARY-MACRO-OUTPUT-END--", "name": "JinjaLogInfo", "pid": 76, "thread": "MainThread", "ts": "2026-05-24T20:42:50.446640Z"}}
