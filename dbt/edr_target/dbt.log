{"data": {"conn_name": "macro_log_macro_results", "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"0913bcaf-02e4-49e1-816b-47d9cf6562fe\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n        with model_runs as (\n            select\n                *,\n                row_number() over (partition by unique_id order by generated_at desc) as invocations_rank_index\n            from \"fraud_warehouse\".\"main_elementary\".\"model_run_results\"\n        )\n\n        select\n            unique_id,\n            invocation_id,\n            name,\n            schema_name as schema,\n            status,\n            case\n                when status != 'success' then 0\n                else round(cast(execution_time as numeric(28,6)), 1)\n            end as execution_time,\n            full_refresh,\n            materialization,\n            case when invocations_rank_index = 1 then compiled_code else NULL end as compiled_code,\n            generated_at\n        from model_runs\n        where \n        (date_diff('day', cast(generated_at as timestamp)::timestamp, \n    current_timestamp::timestamp\n::timestamp ))\n     < 7\n        \n          and unique_id not like 'model.elementary.%'\n        \n        order by generated_at\n    \n\n  "}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "0913bcaf-02e4-49e1-816b-47d9cf6562fe", "level": "debug", "msg": "On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"0913bcaf-02e4-49e1-816b-47d9cf6562fe\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n        with model_runs as (\n            select\n                *,\n                row_number() over (partition by unique_id order by generated_at desc) as invocations_rank_index\n            from \"fraud_warehouse\".\"main_elementary\".\"model_run_results\"\n        )\n\n        select\n            unique_id,\n            invocation_id,\n            name,\n            schema_name as schema,\n            status,\n            case\n                when status != 'success' then 0\n                else round(cast(execution_time as numeric(28,6)), 1)\n            end as execution_time,\n            full_refresh,\n            materialization,\n            case when invocations_rank_index = 1 then compiled_code else NULL end as compiled_code,\n            generated_at\n        from model_runs\n        where \n        (date_diff('day', cast(generated_at as timestamp)::timestamp, \n    current_timestamp::timestamp\n::timestamp ))\n     < 7\n        \n          and unique_id not like 'model.elementary.%'\n        \n        order by generated_at\n    \n\n  ", "name": "SQLQuery", "pid": 76, "thread": "MainThread", "ts": "2026-05-24T20:42:50.396764Z"}}
