{"data": {"conn_name": "macro_log_macro_results", "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"e555b602-97f1-4d82-a162-735db81b3a75\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n    with ordered_run_results as (\n      select\n        run_results.invocation_id,\n        row_number() over (partition by run_results.unique_id order by run_results.generated_at desc) as row_number\n      from \"fraud_warehouse\".\"main_elementary\".\"dbt_run_results\" run_results\n      join \"fraud_warehouse\".\"main_elementary\".\"dbt_models\" models on run_results.unique_id = models.unique_id\n    ),\n\n    latest_models_invocations as (\n      select distinct invocation_id\n      from ordered_run_results\n      where row_number = 1\n    )\n\n    select\n      invocations.invocation_id,\n      invocations.command,\n      invocations.selected,\n      invocations.full_refresh,\n      \n        invocations.job_url,\n      \n      invocations.job_name,\n      invocations.job_id,\n      invocations.orchestrator\n    from \"fraud_warehouse\".\"main_elementary\".\"dbt_invocations\" invocations\n    join latest_models_invocations on invocations.invocation_id = latest_models_invocations.invocation_id\n  \n\n  "}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "e555b602-97f1-4d82-a162-735db81b3a75", "level": "debug", "msg": "On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n    \n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"e555b602-97f1-4d82-a162-735db81b3a75\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n    \n    with ordered_run_results as (\n      select\n        run_results.invocation_id,\n        row_number() over (partition by run_results.unique_id order by run_results.generated_at desc) as row_number\n      from \"fraud_warehouse\".\"main_elementary\".\"dbt_run_results\" run_results\n      join \"fraud_warehouse\".\"main_elementary\".\"dbt_models\" models on run_results.unique_id = models.unique_id\n    ),\n\n    latest_models_invocations as (\n      select distinct invocation_id\n      from ordered_run_results\n      where row_number = 1\n    )\n\n    select\n      invocations.invocation_id,\n      invocations.command,\n      invocations.selected,\n      invocations.full_refresh,\n      \n        invocations.job_url,\n      \n      invocations.job_name,\n      invocations.job_id,\n      invocations.orchestrator\n    from \"fraud_warehouse\".\"main_elementary\".\"dbt_invocations\" invocations\n    join latest_models_invocations on invocations.invocation_id = latest_models_invocations.invocation_id\n  \n\n  ", "name": "SQLQuery", "pid": 76, "thread": "MainThread", "ts": "2026-05-24T20:42:55.738455Z"}}
