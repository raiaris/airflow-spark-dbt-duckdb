{"data": {"conn_name": "macro_log_macro_results", "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n      select\n          column_name,\n          data_type,\n          character_maximum_length,\n          numeric_precision,\n          numeric_scale\n\n      from system.information_schema.columns\n      where table_name = 'dbt_source_freshness_results'\n      \n      and table_schema = 'main_elementary'\n      \n      \n      and table_catalog = 'fraud_warehouse'\n      \n      order by ordinal_position\n\n  "}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "690bbdc7-8aa8-4b94-a594-a9bd08f65041", "level": "debug", "msg": "On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\n\n      select\n          column_name,\n          data_type,\n          character_maximum_length,\n          numeric_precision,\n          numeric_scale\n\n      from system.information_schema.columns\n      where table_name = 'dbt_source_freshness_results'\n      \n      and table_schema = 'main_elementary'\n      \n      \n      and table_catalog = 'fraud_warehouse'\n      \n      order by ordinal_position\n\n  ", "name": "SQLQuery", "pid": 76, "thread": "MainThread", "ts": "2026-05-24T20:42:43.011638Z"}}
