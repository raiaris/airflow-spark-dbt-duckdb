{"data": {"conn_name": "macro_log_macro_results", "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\nselect\n      'fraud_warehouse' as database,\n      table_name as name,\n      table_schema as schema,\n      CASE table_type\n        WHEN 'BASE TABLE' THEN 'table'\n        WHEN 'VIEW' THEN 'view'\n        WHEN 'LOCAL TEMPORARY' THEN 'table'\n        END as type\n    from system.information_schema.tables\n    where table_schema = 'main_elementary'\n    and table_catalog = 'fraud_warehouse'\n  "}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "d3bb19a6-fcd7-421c-82bb-fff5801ebe61", "level": "debug", "msg": "On macro_log_macro_results: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */\nselect\n      'fraud_warehouse' as database,\n      table_name as name,\n      table_schema as schema,\n      CASE table_type\n        WHEN 'BASE TABLE' THEN 'table'\n        WHEN 'VIEW' THEN 'view'\n        WHEN 'LOCAL TEMPORARY' THEN 'table'\n        END as type\n    from system.information_schema.tables\n    where table_schema = 'main_elementary'\n    and table_catalog = 'fraud_warehouse'\n  ", "name": "SQLQuery", "pid": 76, "thread": "MainThread", "ts": "2026-05-24T20:42:47.127425Z"}}
